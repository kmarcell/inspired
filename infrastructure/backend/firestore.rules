rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requester is the owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper to check if user is a member of a community
    function isMember(communityId) {
      return request.auth != null && communityId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.joinedCommunities;
    }

    // Helper to check if a community is public
    function isCommunityPublic(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)).data.privacySettings.isPublic == true;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow get: if request.auth != null && resource.data.privacySettings.isProfilePublic == true;
      allow write: if isOwner(userId) && 
        (request.resource.data.privacySettings.isProfilePublic == false || 
         request.resource.data.privacySettings.avatarPrivacy == "public");
      allow update: if isOwner(userId) && 
        (request.resource.data.joinedCommunities.size() >= resource.data.joinedCommunities.size());
    }
    
    // 2. Yoga Studios
    match /studios/{studioId} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }

    // 3. Communities
    match /communities/{communityId} {
      allow get: if resource.data.privacySettings.isPublic == true || isMember(communityId);
      allow list: if resource.data.privacySettings.isPublic == true;
      allow write: if false; // TBD: Admin logic
    }
    
    // 4. Community Posts
    match /posts/{postId} {
      // Area posts are public. Community posts depend on community privacy or membership.
      allow read: if resource.data.source.type == "area" || 
                    isCommunityPublic(resource.data.source.id) || 
                    isMember(resource.data.source.id);
                    
      allow create: if request.auth != null && 
                      request.resource.data.author.id == request.auth.uid &&
                      (request.resource.data.source.type == "area" || isMember(request.resource.data.source.id));
                      
      allow update, delete: if request.auth != null && resource.data.author.id == request.auth.uid;
    }
    
    // 5. Comments (Sub-collection)
    match /posts/{postId}/comments/{commentId} {
      allow read: if true; // Linked to parent post visibility in real-world, keeping simple for now
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.author.id == request.auth.uid;
    }
    
    // 6. Likes (Sub-collection)
    match /posts/{postId}/likes/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
